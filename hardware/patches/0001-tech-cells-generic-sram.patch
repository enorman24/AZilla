+  /**
+   * Memory loader for simulation
+   *
+   * Include this file in a memory primitive to load a memory array from
+   * simulation.
+   *
+   * Requirements:
+   * - A memory array named `sram`.
+   * - A parameter `DataWidth` giving the memory width (word size) in bit.
+   * - A parameter `NumWords` giving the memory depth in words.
+   */
+
+  `ifndef SYNTHESIS
+  // Task for loading 'sram' with SystemVerilog system task $readmemh()
+  export "DPI-C" task simutil_memload;
+
+  task simutil_memload;
+    input string file;
+    $readmemh(file, sram);
+  endtask
+
+  // Function for setting a specific element in |sram|
+  // Returns 1 (true) for success, 0 (false) for errors.
+  export "DPI-C" function simutil_set_mem;
+  function int simutil_set_mem(input int index, input bit [511:0] val);
+    automatic int unsigned chunks_per_word = (DataWidth + 511) / 512;
+    automatic int unsigned word_index = index / chunks_per_word;
+    automatic int unsigned chunk_index = index % chunks_per_word;
+    automatic int unsigned bit_offset = chunk_index * 512;
+    automatic int unsigned chunk_width =
+        (DataWidth - bit_offset > 512) ? 512 : DataWidth - bit_offset;
+
+    if (index < 0)
+      return 0;
+    if (word_index >= NumWords)
+      return 0;
+
+    for (int unsigned i = 0; i < 512; i++) begin
+      if (i < chunk_width) begin
+        sram[word_index][bit_offset+i] = val[i];
+      end
+    end
+
+    return 1;
+  endfunction
+
+  // Function for getting a specific element in |sram|
+  export "DPI-C" function simutil_get_mem;
+  function int simutil_get_mem(input int index, output bit [511:0] val);
+    automatic int unsigned chunks_per_word = (DataWidth + 511) / 512;
+    automatic int unsigned word_index = index / chunks_per_word;
+    automatic int unsigned chunk_index = index % chunks_per_word;
+    automatic int unsigned bit_offset = chunk_index * 512;
+    automatic int unsigned chunk_width =
+        (DataWidth - bit_offset > 512) ? 512 : DataWidth - bit_offset;
+
+    if (index < 0)
+      return 0;
+    if (word_index >= NumWords)
+      return 0;
+
+    val = 0;
+    for (int unsigned i = 0; i < 512; i++) begin
+      if (i < chunk_width) begin
+        val[i] = sram[word_index][bit_offset+i];
+      end
+    end
+
+    return 1;
+  endfunction
+  `endif
+
 endmodule
